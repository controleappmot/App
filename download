import { useMemo, useState } from 'react'
import { useData } from '../contexts/DataContext'
import { StatCard, MetricRow } from '../components/StatCard'
import EarningModal from '../components/EarningModal'
import ExpenseModal from '../components/ExpenseModal'
import { StartJourneyModal, EndJourneyModal } from '../components/JourneyModals'
import { IconPlay, IconStop, IconRoute, IconWallet, IconReceipt } from '../components/icons'
import { todayISO, formatDuration, formatTime } from '../lib/dates'
import {
  buildDailyMap,
  summaryForToday,
  summaryForWeek,
  summaryForMonth,
  summarize,
  daysInRange,
  formatBRL,
} from '../lib/calculations'

export default function Dashboard() {
  const { journeys, earnings, expenses, loading, activeJourney } = useData()
  const [earnOpen, setEarnOpen] = useState(false)
  const [expOpen, setExpOpen] = useState(false)
  const [startOpen, setStartOpen] = useState(false)
  const [endOpen, setEndOpen] = useState(false)

  const { today, week, month, indicators } = useMemo(() => {
    const map = buildDailyMap(journeys, earnings, expenses)
    const t = todayISO()
    const monthDays = daysInRange(map, t.slice(0, 8) + '01', t)
    return {
      today: summaryForToday(map, t),
      week: summaryForWeek(map, t),
      month: summaryForMonth(map, t),
      indicators: summarize(monthDays), // indicadores do mês corrente
    }
  }, [journeys, earnings, expenses])

  if (loading) {
    return <div className="text-center text-muted py-20">Carregando…</div>
  }

  return (
    <div className="space-y-6">
      {/* Status da jornada — iniciar/encerrar acontece aqui mesmo */}
      {activeJourney ? (
        <div className="card w-full p-4 border-brand/40 bg-brand-dim/40">
          <div className="flex items-center gap-3">
            <span className="w-10 h-10 rounded-xl bg-brand/20 text-brand flex items-center justify-center shrink-0">
              <IconRoute width={20} height={20} />
            </span>
            <div className="flex-1 min-w-0">
              <div className="flex items-center gap-2">
                <span className="w-2 h-2 rounded-full bg-brand animate-pulse" />
                <span className="font-semibold text-brand">Jornada em andamento</span>
              </div>
              <p className="text-sm text-muted mt-0.5">
                Iniciada às {formatTime(activeJourney.start_time)} · KM {activeJourney.start_km}
              </p>
            </div>
          </div>
          <button className="btn-danger w-full mt-3" onClick={() => setEndOpen(true)}>
            <IconStop width={18} height={18} /> Encerrar jornada
          </button>
        </div>
      ) : (
        <button onClick={() => setStartOpen(true)} className="btn-primary w-full">
          <IconPlay width={18} height={18} /> Iniciar jornada
        </button>
      )}

      {/* Acesso rápido: lançar ganho/gasto direto do painel */}
      <div className="grid grid-cols-2 gap-3">
        <button
          onClick={() => setEarnOpen(true)}
          className="btn bg-gain/15 text-gain border border-gain/30 hover:bg-gain/25"
        >
          <IconWallet width={18} height={18} /> + Ganho
        </button>
        <button
          onClick={() => setExpOpen(true)}
          className="btn bg-loss/15 text-loss border border-loss/30 hover:bg-loss/25"
        >
          <IconReceipt width={18} height={18} /> + Gasto
        </button>
      </div>

      {/* Hoje */}
      <section>
        <h2 className="text-sm font-semibold text-muted uppercase tracking-wide mb-3">Hoje</h2>
        <div className="grid grid-cols-2 gap-3">
          <StatCard label="Ganhos" value={formatBRL(today.earnings)} tone="gain" />
          <StatCard label="Gastos" value={formatBRL(today.expenses)} tone="loss" />
          <StatCard
            label="Lucro líquido"
            value={formatBRL(today.profit)}
            tone={today.profit >= 0 ? 'brand' : 'loss'}
          />
          <StatCard
            label="Trabalho"
            value={formatDuration(today.hours)}
            hint={`${today.km.toFixed(0)} km rodados`}
          />
        </div>
      </section>

      {/* Semana e Mês */}
      <div className="grid sm:grid-cols-2 gap-4">
        <section className="card p-4">
          <h2 className="text-sm font-semibold text-muted uppercase tracking-wide mb-1">
            Esta semana
          </h2>
          <MetricRow label="Ganhos" value={formatBRL(week.earnings)} tone="gain" />
          <MetricRow label="Gastos" value={formatBRL(week.expenses)} tone="loss" />
          <MetricRow
            label="Lucro líquido"
            value={formatBRL(week.profit)}
            tone={week.profit >= 0 ? 'gain' : 'loss'}
          />
        </section>

        <section className="card p-4">
          <h2 className="text-sm font-semibold text-muted uppercase tracking-wide mb-1">
            Este mês
          </h2>
          <MetricRow label="Ganhos" value={formatBRL(month.earnings)} tone="gain" />
          <MetricRow label="Gastos" value={formatBRL(month.expenses)} tone="loss" />
          <MetricRow
            label="Lucro líquido"
            value={formatBRL(month.profit)}
            tone={month.profit >= 0 ? 'gain' : 'loss'}
          />
        </section>
      </div>

      {/* Indicadores automáticos (mês corrente) */}
      <section className="card p-4">
        <h2 className="text-sm font-semibold text-muted uppercase tracking-wide mb-1">
          Indicadores do mês
        </h2>
        <MetricRow label="Ganho por KM" value={formatBRL(indicators.ganhoPorKm)} />
        <MetricRow label="Lucro por KM" value={formatBRL(indicators.lucroPorKm)} />
        <MetricRow label="Ganho por hora" value={formatBRL(indicators.ganhoPorHora)} />
        <MetricRow label="Lucro por hora" value={formatBRL(indicators.lucroPorHora)} />
        <MetricRow label="Ticket médio diário" value={formatBRL(indicators.ticketMedioDiario)} />
        <p className="text-xs text-muted mt-2">
          Base: {indicators.workedDays} dia(s) · {indicators.km.toFixed(0)} km ·{' '}
          {formatDuration(indicators.hours)}
        </p>
      </section>

      <EarningModal open={earnOpen} onClose={() => setEarnOpen(false)} />
      <ExpenseModal open={expOpen} onClose={() => setExpOpen(false)} />
      <StartJourneyModal open={startOpen} onClose={() => setStartOpen(false)} />
      <EndJourneyModal open={endOpen} onClose={() => setEndOpen(false)} />
    </div>
  )
}
