import { useMemo } from 'react'
import { useData } from '../contexts/DataContext'
import { MetricRow } from '../components/StatCard'
import {
  buildDailyMap,
  daysInRange,
  weekdayRanking,
  hourlyRanking,
  bestGanhoPorHora,
  bestLucroPorKm,
  weeklyAverage,
  formatBRL,
} from '../lib/calculations'
import { todayISO, weekdayName, formatFullDate } from '../lib/dates'

const MEDALS = ['🥇', '🥈', '🥉']

export default function Inteligencia() {
  const { journeys, earnings, expenses } = useData()

  const intel = useMemo(() => {
    const map = buildDailyMap(journeys, earnings, expenses)
    const allDays = daysInRange(map, '0000-01-01', todayISO())
    return {
      weekdays: weekdayRanking(allDays),
      hours: hourlyRanking(earnings),
      bestHour: bestGanhoPorHora(allDays),
      bestKm: bestLucroPorKm(allDays),
      weekly: weeklyAverage(allDays),
      hasData: allDays.length > 0,
    }
  }, [journeys, earnings, expenses])

  if (!intel.hasData) {
    return (
      <div className="space-y-4">
        <h1 className="text-xl font-bold">Análise</h1>
        <p className="text-center text-muted text-sm py-16">
          Registre algumas jornadas e ganhos para o app descobrir seus melhores dias e horários.
        </p>
      </div>
    )
  }

  const maxHour = Math.max(1, ...intel.hours.buckets.map((b) => b.earnings))

  return (
    <div className="space-y-6">
      <header>
        <h1 className="text-xl font-bold">Análise</h1>
        <p className="text-sm text-muted">Onde está o seu melhor dinheiro.</p>
      </header>

      {/* Destaques */}
      <div className="grid grid-cols-1 gap-3">
        <div className="card p-4 border-brand/30 bg-brand-dim/20">
          <span className="text-xs text-muted uppercase tracking-wide">Melhor ganho por hora</span>
          {intel.bestHour ? (
            <div className="mt-1">
              <div className="font-mono text-xl sm:text-2xl font-bold text-brand">
                {formatBRL(intel.bestHour.value)}<span className="text-sm text-muted">/h</span>
              </div>
              <p className="text-sm text-muted mt-0.5">
                {weekdayName(intel.bestHour.date)}, {formatFullDate(intel.bestHour.date)}
              </p>
            </div>
          ) : (
            <p className="text-sm text-muted mt-1">Registre jornadas com horas para calcular.</p>
          )}
        </div>

        <div className="card p-4">
          <span className="text-xs text-muted uppercase tracking-wide">Melhor lucro por KM</span>
          {intel.bestKm ? (
            <div className="mt-1">
              <div className="font-mono text-xl sm:text-2xl font-bold text-gain">
                {formatBRL(intel.bestKm.value)}<span className="text-sm text-muted">/km</span>
              </div>
              <p className="text-sm text-muted mt-0.5">
                {weekdayName(intel.bestKm.date)}, {formatFullDate(intel.bestKm.date)}
              </p>
            </div>
          ) : (
            <p className="text-sm text-muted mt-1">Registre jornadas com KM para calcular.</p>
          )}
        </div>
      </div>

      {/* Dias mais lucrativos */}
      <section className="card p-4">
        <h2 className="text-sm font-semibold text-muted uppercase tracking-wide mb-2">
          Dias da semana mais lucrativos
        </h2>
        <div className="space-y-1">
          {intel.weekdays.map((w, i) => (
            <div
              key={w.weekday}
              className="flex items-center gap-3 py-2 border-b border-line last:border-0"
            >
              <span className="w-6 text-center">{MEDALS[i] ?? <span className="text-muted text-sm">{i + 1}º</span>}</span>
              <div className="flex-1">
                <div className="text-sm font-medium">{w.name}</div>
                <div className="text-xs text-muted">
                  {w.days} dia(s) · média {formatBRL(w.avgProfit)}/dia
                </div>
              </div>
              <span className="font-mono font-semibold text-gain">{formatBRL(w.profit)}</span>
            </div>
          ))}
        </div>
      </section>

      {/* Horários mais lucrativos */}
      <section className="card p-4">
        <h2 className="text-sm font-semibold text-muted uppercase tracking-wide mb-1">
          Horários mais lucrativos
        </h2>
        <p className="text-xs text-muted mb-3">Ranking por ganho, com base na hora informada nos lançamentos.</p>
        <div className="space-y-2.5">
          {intel.hours.buckets.map((b, i) => (
            <div key={b.label}>
              <div className="flex items-center justify-between text-sm mb-1">
                <span className="font-mono">
                  <span className="text-muted">{i + 1}º</span> {b.label}
                </span>
                <span className="font-mono font-semibold text-gain">{formatBRL(b.earnings)}</span>
              </div>
              <div className="h-1.5 rounded-full bg-surface-2 overflow-hidden">
                <div
                  className="h-full bg-brand rounded-full"
                  style={{ width: `${(b.earnings / maxHour) * 100}%` }}
                />
              </div>
            </div>
          ))}
        </div>
        {intel.hours.semHora > 0 && (
          <p className="text-xs text-muted mt-3">
            {formatBRL(intel.hours.semHora)} em ganhos sem hora informada não entram neste ranking.
          </p>
        )}
      </section>

      {/* Média semanal */}
      <section className="card p-4">
        <h2 className="text-sm font-semibold text-muted uppercase tracking-wide mb-1">
          Média por semana
        </h2>
        <MetricRow label="Ganho médio" value={formatBRL(intel.weekly.avgEarnings)} tone="gain" />
        <MetricRow label="Gasto médio" value={formatBRL(intel.weekly.avgExpenses)} tone="loss" />
        <MetricRow label="Lucro médio" value={formatBRL(intel.weekly.avgProfit)} tone="gain" />
        <p className="text-xs text-muted mt-2">Base: {intel.weekly.weeks} semana(s) com registros.</p>
      </section>
    </div>
  )
}
