import { useMemo, useState } from 'react'
import { useData } from '../contexts/DataContext'
import EarningModal from '../components/EarningModal'
import { IconPlus, IconTrash } from '../components/icons'
import { formatFullDate } from '../lib/dates'
import { formatBRL } from '../lib/calculations'
import { PLATFORM_LABEL, type Earning } from '../lib/types'

export default function Ganhos() {
  const { earnings, deleteEarning } = useData()
  const [open, setOpen] = useState(false)

  const grouped = useMemo(() => {
    const map = new Map<string, Earning[]>()
    for (const e of earnings) {
      const arr = map.get(e.date) ?? []
      arr.push(e)
      map.set(e.date, arr)
    }
    return [...map.entries()].sort((a, b) => b[0].localeCompare(a[0]))
  }, [earnings])

  return (
    <div className="space-y-6">
      <header className="flex items-end justify-between">
        <div>
          <h1 className="text-xl font-bold">Ganhos</h1>
          <p className="text-sm text-muted">Lance cada recebimento da Uber e da 99.</p>
        </div>
        <button className="btn-primary !px-3 !py-2" onClick={() => setOpen(true)}>
          <IconPlus width={18} height={18} /> Novo
        </button>
      </header>

      <section className="space-y-4">
        {grouped.length === 0 && (
          <p className="text-center text-muted text-sm py-10">Nenhum ganho registrado ainda.</p>
        )}
        {grouped.map(([day, items]) => {
          const total = items.reduce((s, e) => s + e.amount, 0)
          return (
            <div key={day}>
              <div className="flex items-center justify-between mb-2 px-1">
                <h3 className="text-sm font-semibold">{formatFullDate(day)}</h3>
                <span className="text-sm font-mono font-semibold text-gain">{formatBRL(total)}</span>
              </div>
              <div className="space-y-2">
                {items.map((e) => (
                  <div key={e.id} className="card p-3.5 flex items-center gap-3">
                    <span
                      className="chip shrink-0"
                      style={{
                        background: e.platform === 'uber' ? 'rgba(62,166,255,.15)' : 'rgba(255,196,0,.15)',
                        color: e.platform === 'uber' ? '#3ea6ff' : '#ffc400',
                      }}
                    >
                      {PLATFORM_LABEL[e.platform]}
                    </span>
                    <div className="flex-1 min-w-0">
                      <div className="font-mono font-semibold text-gain">{formatBRL(e.amount)}</div>
                      {(e.earned_time || e.notes) && (
                        <div className="text-xs text-muted truncate">
                          {e.earned_time && e.earned_time.slice(0, 5)}
                          {e.earned_time && e.notes && ' · '}
                          {e.notes}
                        </div>
                      )}
                    </div>
                    <button
                      onClick={() => { if (confirm('Excluir este ganho?')) deleteEarning(e.id) }}
                      className="text-muted hover:text-loss p-1.5 shrink-0"
                      aria-label="Excluir"
                    >
                      <IconTrash width={18} height={18} />
                    </button>
                  </div>
                ))}
              </div>
            </div>
          )
        })}
      </section>

      <EarningModal open={open} onClose={() => setOpen(false)} />
    </div>
  )
}
